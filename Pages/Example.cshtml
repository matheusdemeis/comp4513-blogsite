@page
@model ExampleModel
@{
    string? message = "Hello From Razor Pages";
}

<h1>Example page</h1>

<p>Hello, @Model.Name</p>
<p>Today is @ViewData["Date"]</p>

<form method="post">
    <label>Enter your name</label>
    <input type="text" name="Name">
    <input type="submit" value="save">
</form>

<p>@message</p>

@{
    List<string> words = new List<string> {
        "The", "quick", "fox", "jumps", "over", "the", "lazy", "river"
    };
}

@foreach (var word in words)
{
    <span>@word </span>
}